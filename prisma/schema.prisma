generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id                           String                         @id @default(uuid())
  name                         String
  plan                         SubscriptionPlan               @default(BASIC)
  active                       Boolean                        @default(true)
  suspended                    Boolean                        @default(false)
  suspensionReason             String?                        @map("suspension_reason")
  suspendedAt                  DateTime?                      @map("suspended_at")
  createdAt                    DateTime                       @default(now()) @map("created_at")
  updatedAt                    DateTime                       @updatedAt @map("updated_at")
  academic_years               academic_years[]
  announcements                Announcement[]
  assessments                  Assessment[]
  attendance                   Attendance[]
  classAnnouncements           ClassAnnouncement[]
  classSubjectTeachers         ClassSubjectTeacher[]
  classes                      Class[]
  timetableSlots               TimetableSlot[]
  videoCourses                 VideoCourse[]
  courseEnrollments            CourseEnrollment[]
  dashboard_academic_summaries dashboard_academic_summaries[]
  dashboard_aggregation_events dashboard_aggregation_events[]
  deletionRequests             DeletionRequest[]              @relation("DeletionRequests")
  expenseAuditLogs             ExpenseAuditLog[]
  expenses                     Expense[]
  fundRequests                 FundRequest[]
  feePayments                  FeePayment[]
  feeAdjustments               FeeAdjustment[]
  feeInvoices                  FeeInvoice[]
  studentLicenses              StudentLicense[]
  studentLicensePayments       StudentLicensePayment[]
  feeSchedules                 FeeSchedule[]
  messages                     Message[]
  parentComplaints             ParentComplaint[]
  parentInteractions           ParentInteraction[]
  results                      Result[]
  schoolBilling                SchoolBilling?
  schoolSettings               SchoolSettings?
  reportTemplates              ReportTemplate[]
  students                     Student[]
  subjects                     Subject[]
  teacherContracts             TeacherContract[]
  teacherSalaries              TeacherSalary[]
  teacherSalaryConfigs         TeacherSalaryConfig[]
  teacher_off_days             teacher_off_days[]
  terms                        terms[]
  users                        User[]

  @@map("schools")
}

model GlobalSystemSettings {
  id                          String   @id @default(uuid())
  key                         String   @unique
  videoCoursesGloballyEnabled Boolean  @default(true) @map("video_courses_globally_enabled")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@map("global_system_settings")
}

model SchoolSettings {
  id                        String          @id @default(uuid())
  schoolId                  String          @unique @map("school_id")
  expenseApprovalThreshold  Float           @default(0) @map("expense_approval_threshold")
  minimumPassRatePerSubject Float           @default(50) @map("minimum_pass_rate_per_subject")
  currency                  String          @default("ZAR") @map("currency")
  logoUrl                   String?         @map("logo_url")
  slogan                    String?         @map("slogan")
  autoInvoiceEnabled        Boolean         @default(false) @map("auto_invoice_enabled")
  invoiceDayOfMonth         Int             @default(1) @map("invoice_day_of_month")
  feesDueDayOfMonth         Int             @default(15) @map("fees_due_day_of_month")
  invoiceActiveMonths       Int[]           @default([]) @map("invoice_active_months")
  reportTemplate            Int             @default(1) @map("report_template")
  activeTemplateId          String?         @map("active_template_id")
  allowCrossSchoolCourses   Boolean         @default(false) @map("allow_cross_school_courses")
  videoCoursesEnabled       Boolean         @default(true) @map("video_courses_enabled")
  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")
  school                    School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  activeTemplate            ReportTemplate? @relation("ActiveTemplate", fields: [activeTemplateId], references: [id])

  @@map("school_settings")
}

model SchoolBilling {
  id                   String                 @id @default(uuid())
  schoolId             String                 @unique @map("school_id")
  onboardingFee        Float                  @default(0) @map("onboarding_fee")
  onboardingStatus     SchoolOnboardingStatus @default(PENDING) @map("onboarding_status")
  annualPricePerStudent Float                 @default(0) @map("annual_price_per_student")
  licensedStudentCount Int                    @default(0) @map("licensed_student_count")
  billingYear          Int                    @default(0) @map("billing_year")
  licenseStartDate     DateTime?              @map("license_start_date") @db.Date
  licenseEndDate       DateTime?              @map("license_end_date") @db.Date
  enabledModules       String[]               @default([]) @map("enabled_modules")
  notes                String?
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  school               School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  payments             SchoolBillingPayment[]

  @@index([billingYear])
  @@map("school_billing")
}

enum BillingPaymentType {
  ONBOARDING
  ANNUAL
  ADJUSTMENT
}

enum StudentLicenseSource {
  BULK
  EXTRA_PAYMENT
}

model SchoolBillingPayment {
  id            String             @id @default(uuid())
  billingId     String             @map("billing_id")
  amount        Float
  paymentType   BillingPaymentType @map("payment_type")
  paymentDate   DateTime           @map("payment_date") @db.Date
  paymentMethod String?            @map("payment_method")
  referenceNumber String?          @map("reference_number")
  notes         String?
  recordedById  String?            @map("recorded_by_id")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  billing       SchoolBilling      @relation(fields: [billingId], references: [id], onDelete: Cascade)
  recordedBy    User?              @relation("BillingPaymentRecorder", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([billingId])
  @@index([paymentDate])
  @@map("school_billing_payments")
}

model User {
  id                       String                 @id @default(uuid())
  schoolId                 String?                @map("school_id")
  email                    String                 @unique
  username                 String?                @unique
  password                 String
  mustResetPassword        Boolean                @default(false) @map("must_reset_password")
  role                     UserRole
  preferredLanguage        String                 @default("en") @map("preferred_language")
  firstName                String?                @map("first_name")
  lastName                 String?                @map("last_name")
  title                    String?
  phone                    String?
  suspended                Boolean                @default(false)
  suspendedAt              DateTime?              @map("suspended_at")
  suspensionReason         String?                @map("suspension_reason")
  studentId                String?                @unique @map("student_id")
  createdAt                DateTime               @default(now()) @map("created_at")
  updatedAt                DateTime               @updatedAt @map("updated_at")
  announcements            Announcement[]         @relation("AnnouncementCreator")
  assessmentsCreated       Assessment[]           @relation("TeacherAssessments")
  classAnnouncements       ClassAnnouncement[]    @relation("ClassAnnouncementCreator")
  teachingAssignments      ClassSubjectTeacher[]  @relation("TeacherSubjectAssignments")
  teacherClasses           Class[]                @relation("TeacherClasses")
  deletionRequestsApproved DeletionRequest[]      @relation("DeleteRequestsApproved")
  deletionRequestsCreated  DeletionRequest[]      @relation("DeleteRequestsCreated")
  expenseAuditLogs         ExpenseAuditLog[]      @relation("ExpenseAuditActor")
  expensesCreated          Expense[]              @relation("ExpenseCreatedBy")
  expensesUpdated          Expense[]              @relation("ExpenseUpdatedBy")
  billingPaymentsRecorded  SchoolBillingPayment[] @relation("BillingPaymentRecorder")
  fundRequestsCreated      FundRequest[]          @relation("FundRequestedBy")
  fundRequestsReviewed     FundRequest[]          @relation("FundRequestReviewedBy")
  feePaymentsReceived      FeePayment[]           @relation("FeePaymentReceivedBy")
  studentLicensePaymentsRecorded StudentLicensePayment[] @relation("StudentLicensePaymentRecorder")
  feeSchedulesApproved     FeeSchedule[]          @relation("FeeScheduleApprovedBy")
  feeSchedulesCreated      FeeSchedule[]          @relation("FeeScheduleCreatedBy")
  feeAdjustmentsCreated    FeeAdjustment[]        @relation("FeeAdjustmentCreatedBy")
  receivedMessages         Message[]              @relation("ReceivedMessages")
  sentMessages             Message[]              @relation("SentMessages")
  parentComplaints         ParentComplaint[]      @relation("ParentComplaints")
  parentInteractions       ParentInteraction[]    @relation("ParentInteractions")
  classHistoryChanges      StudentClassHistory[]  @relation("ClassHistoryChangedBy")
  studentStatusChanges     StudentStatusHistory[] @relation("StudentStatusChangedBy")
  students                 Student[]              @relation("ParentStudents")
  teacherContracts         TeacherContract[]      @relation("TeacherContracts")
  teacherSalaries          TeacherSalary[]        @relation("TeacherSalaries")
  salariesRecorded         TeacherSalary[]        @relation("SalaryRecordedBy")
  teacherSalaryConfig      TeacherSalaryConfig?   @relation("TeacherSalaryConfig")
  salaryConfigsUpdated     TeacherSalaryConfig[]  @relation("SalaryConfigUpdatedBy")
  teacher_off_days         teacher_off_days[]
  reportTemplatesCreated   ReportTemplate[]       @relation("ReportTemplateCreator")
  settings                 UserSettings?
  linkedStudent            Student?               @relation("StudentUser")
  timetableSlotsTeaching   TimetableSlot[]        @relation("TimetableSlots")
  coursesCreated           VideoCourse[]          @relation("TeacherCourses")
  school                   School?                @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([email])
  @@map("users")
}

model UserSettings {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  preferredLanguage String   @default("en") @map("preferred_language")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Class {
  id                 String                @id @default(uuid())
  schoolId           String                @map("school_id")
  name               String
  academicYear       Int                   @map("academic_year")
  academicYearId     String?               @map("academic_year_id")
  teacherId          String?               @map("teacher_id")
  grade              String?
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  capacity           Int?                  @map("capacity")
  assessments        Assessment[]
  announcements      ClassAnnouncement[]
  subjectAssignments ClassSubjectTeacher[]
  school             School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher            User?                 @relation("TeacherClasses", fields: [teacherId], references: [id])
  academicYearRecord academic_years?       @relation(fields: [academicYearId], references: [id])
  classHistoryFrom   StudentClassHistory[] @relation("ClassHistoryFrom")
  classHistoryTo     StudentClassHistory[] @relation("ClassHistoryTo")
  feeSchedules       FeeSchedule[]       @relation("FeeScheduleClass")
  students           Student[]
  additionalEnrollments StudentAdditionalClass[]
  timetableSlots     TimetableSlot[]

  @@unique([schoolId, name, academicYear])
  @@index([schoolId])
  @@index([teacherId])
  @@index([academicYear])
  @@index([academicYearId])
  @@map("classes")
}

model TeacherContract {
  id        String                @id @default(uuid())
  schoolId  String                @map("school_id")
  teacherId String                @map("teacher_id")
  title     String?
  startDate DateTime              @map("start_date") @db.Date
  endDate   DateTime              @map("end_date") @db.Date
  status    TeacherContractStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")
  school    School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher   User                  @relation("TeacherContracts", fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, startDate, endDate])
  @@index([schoolId])
  @@index([teacherId])
  @@index([status])
  @@index([endDate])
  @@index([schoolId, status, endDate])
  @@map("teacher_contracts")
}

model TeacherSalary {
  id          String              @id @default(uuid())
  schoolId    String              @map("school_id")
  teacherId   String              @map("teacher_id")
  amount      Float
  paidAmount  Float               @default(0) @map("paid_amount")
  month       Int
  year        Int
  paymentDate DateTime?           @map("payment_date") @db.Date
  status      TeacherSalaryStatus @default(PENDING)
  paidAt      DateTime?           @map("paid_at")
  notes       String?
  recordedBy  String              @map("recorded_by")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  school      School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher     User                @relation("TeacherSalaries", fields: [teacherId], references: [id], onDelete: Cascade)
  recordedByUser User             @relation("SalaryRecordedBy", fields: [recordedBy], references: [id])

  @@unique([teacherId, month, year])
  @@index([schoolId])
  @@index([teacherId])
  @@index([status])
  @@index([schoolId, year, month])
  @@map("teacher_salaries")
}

model TeacherSalaryConfig {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  teacherId    String   @unique @map("teacher_id")
  baseAmount   Float    @map("base_amount")
  notes        String?
  updatedBy    String   @map("updated_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher      User     @relation("TeacherSalaryConfig", fields: [teacherId], references: [id], onDelete: Cascade)
  updatedByUser User    @relation("SalaryConfigUpdatedBy", fields: [updatedBy], references: [id])

  @@index([schoolId])
  @@map("teacher_salary_configs")
}

model ParentComplaint {
  id          String                @id @default(uuid())
  schoolId    String                @map("school_id")
  parentId    String?               @map("parent_id")
  studentId   String?               @map("student_id")
  subject     String
  description String
  status      ParentComplaintStatus @default(OPEN)
  resolvedAt  DateTime?             @map("resolved_at")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  parent      User?                 @relation("ParentComplaints", fields: [parentId], references: [id])
  school      School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student     Student?              @relation(fields: [studentId], references: [id])

  @@index([schoolId])
  @@index([parentId])
  @@index([studentId])
  @@index([status])
  @@index([createdAt])
  @@index([schoolId, status, createdAt])
  @@map("parent_complaints")
}

model Student {
  id                    String                  @id @default(uuid())
  schoolId              String                  @map("school_id")
  classId               String                  @map("class_id")
  parentId              String?                 @map("parent_id")
  parentName            String?                 @map("parent_name")
  parentEmail           String?                 @map("parent_email")
  parentPhone           String?                 @map("parent_phone")
  emergencyContactName  String?                 @map("emergency_contact_name")
  emergencyContactPhone String?                 @map("emergency_contact_phone")
  firstName             String                  @map("first_name")
  lastName              String                  @map("last_name")
  dateOfBirth           DateTime?               @map("date_of_birth")
  admissionNumber       String?                 @map("admission_number")
  status                StudentEnrollmentStatus @default(ACTIVE)
  statusReason          StudentLeaveReason?     @map("status_reason")
  statusDate            DateTime?               @map("status_date")
  statusNotes           String?                 @map("status_notes")
  academicYear          Int                     @map("academic_year")
  userId                String?                 @unique @map("user_id")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")
  studentAssessments    StudentAssessment[]
  attendance            Attendance[]
  feePayments           FeePayment[]
  feeAdjustments        FeeAdjustment[]
  feeInvoices           FeeInvoice[]
  studentLicenses       StudentLicense[]
  studentLicensePayments StudentLicensePayment[]
  complaints            ParentComplaint[]
  results               Result[]
  classHistory          StudentClassHistory[]
  additionalClasses     StudentAdditionalClass[]
  expenses              Expense[]
  statusHistory         StudentStatusHistory[]
  courseEnrollments     CourseEnrollment[]
  courseRatings         CourseRating[]
  class                 Class                   @relation(fields: [classId], references: [id])
  parent                User?                   @relation("ParentStudents", fields: [parentId], references: [id])
  user                  User?                   @relation("StudentUser", fields: [userId], references: [id])
  school                School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, admissionNumber, academicYear])
  @@index([schoolId])
  @@index([classId])
  @@index([academicYear])
  @@index([parentId])
  @@index([parentEmail])
  @@index([schoolId, academicYear])
  @@index([schoolId, createdAt])
  @@map("students")
}

model StudentStatusHistory {
  id          String                  @id @default(uuid())
  studentId   String                  @map("student_id")
  status      StudentEnrollmentStatus
  reason      StudentLeaveReason?
  effectiveAt DateTime                @map("effective_at")
  notes       String?
  changedById String?                 @map("changed_by_id")
  createdAt   DateTime                @default(now()) @map("created_at")
  changedBy   User?                   @relation("StudentStatusChangedBy", fields: [changedById], references: [id])
  student     Student                 @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@index([effectiveAt])
  @@index([changedById])
  @@map("student_status_history")
}

model StudentClassHistory {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  fromClassId String?  @map("from_class_id")
  toClassId   String   @map("to_class_id")
  changedById String?  @map("changed_by_id")
  reason      String?
  effectiveAt DateTime @default(now()) @map("effective_at")
  createdAt   DateTime @default(now()) @map("created_at")
  changedBy   User?    @relation("ClassHistoryChangedBy", fields: [changedById], references: [id])
  fromClass   Class?   @relation("ClassHistoryFrom", fields: [fromClassId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  toClass     Class    @relation("ClassHistoryTo", fields: [toClassId], references: [id])

  @@index([studentId])
  @@index([fromClassId])
  @@index([toClassId])
  @@index([changedById])
  @@index([effectiveAt])
  @@map("student_class_history")
}

model StudentAdditionalClass {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  classId   String   @map("class_id")
  schoolId  String   @map("school_id")
  createdAt DateTime @default(now()) @map("created_at")
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId])
  @@index([classId])
  @@index([schoolId])
  @@map("student_additional_classes")
}

model Subject {
  id               String                @id @default(uuid())
  schoolId         String                @map("school_id")
  name             String
  code             String?
  passRate         Float?                @map("pass_rate")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  assessments      Assessment[]
  classAssignments ClassSubjectTeacher[]
  results          Result[]
  timetableSlots   TimetableSlot[]
  school           School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("subjects")
}

model ClassSubjectTeacher {
  id          String       @id @default(uuid())
  schoolId    String       @map("school_id")
  classId     String       @map("class_id")
  subjectId   String       @map("subject_id")
  teacherId   String       @map("teacher_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  assessments Assessment[]
  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject     Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher     User         @relation("TeacherSubjectAssignments", fields: [teacherId], references: [id])

  @@unique([classId, subjectId])
  @@unique([classId, subjectId, teacherId])
  @@index([schoolId])
  @@index([teacherId])
  @@map("class_subject_teachers")
}

model Assessment {
  id                  String              @id @default(uuid())
  schoolId            String              @map("school_id")
  classId             String              @map("class_id")
  subjectId           String              @map("subject_id")
  teacherId           String              @map("teacher_id")
  termId              String?              @map("term_id")
  academicYear        Int                 @map("academic_year")
  term                String
  title               String
  description         String?
  type                AssessmentType
  totalMarks          Float               @map("total_marks")
  duration            Int?
  dueDate             DateTime?           @map("date")
  published           Boolean             @default(false)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  studentAssessments  StudentAssessment[]
  class               Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  classSubjectTeacher ClassSubjectTeacher @relation(fields: [classId, subjectId, teacherId], references: [classId, subjectId, teacherId])
  school              School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject             Subject             @relation(fields: [subjectId], references: [id])
  teacher             User                @relation("TeacherAssessments", fields: [teacherId], references: [id])
  terms               terms?              @relation(fields: [termId], references: [id])
  questions           Question[]

  @@index([schoolId])
  @@index([classId])
  @@index([subjectId])
  @@index([teacherId])
  @@index([academicYear, term])
  @@index([published])
  @@index([termId])
  @@map("assessments")
}

model Question {
  id            String       @id @default(uuid())
  assessmentId  String       @map("assessment_id")
  questionText  String       @map("question_text")
  type          QuestionType
  marks         Float
  options       Json?
  correctAnswer String?      @map("correct_answer")
  order         Int          @default(0)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  answers       Answer[]
  assessment    Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("questions")
}

model StudentAssessment {
  id           String     @id @default(uuid())
  assessmentId String     @map("assessment_id")
  studentId    String     @map("student_id")
  startedAt    DateTime?  @map("started_at")
  submittedAt  DateTime?  @map("submitted_at")
  score        Float?
  gradedAt     DateTime?  @map("graded_at")
  feedback     String?
  graded       Boolean    @default(false)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  answers      Answer[]
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, studentId])
  @@index([assessmentId])
  @@index([studentId])
  @@map("assessment_scores")
}

model Answer {
  id                  String            @id @default(uuid())
  studentAssessmentId String            @map("student_assessment_id")
  questionId          String            @map("question_id")
  answerText          String?           @map("answer_text")
  score               Float?
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  question            Question          @relation(fields: [questionId], references: [id])
  studentAssessment   StudentAssessment @relation(fields: [studentAssessmentId], references: [id], onDelete: Cascade)

  @@unique([studentAssessmentId, questionId])
  @@index([studentAssessmentId])
  @@index([questionId])
  @@map("answers")
}

model Attendance {
  id        String           @id @default(uuid())
  schoolId  String           @map("school_id")
  studentId String           @map("student_id")
  termId    String?           @map("term_id")
  date      DateTime         @db.Date
  status    AttendanceStatus
  notes     String?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  school    School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  terms     terms?            @relation(fields: [termId], references: [id])

  @@unique([studentId, date])
  @@index([schoolId])
  @@index([studentId])
  @@index([date])
  @@index([schoolId, date])
  @@index([schoolId, date, status])
  @@index([termId])
  @@map("attendance")
}

model Result {
  id         String   @id @default(uuid())
  schoolId   String   @map("school_id")
  studentId  String   @map("student_id")
  subjectId  String   @map("subject_id")
  termId     String?  @map("term_id")
  term       String
  year       Int
  examType   String?  @map("exam_type")
  testScore  Float?   @map("test_score")
