  id         String           @id @default(uuid())
  courseId   String           @map("course_id")
  studentId  String           @map("student_id")
  schoolId   String           @map("school_id")
  paid       Boolean          @default(false)
  paidAt     DateTime?        @map("paid_at")
  amountPaid Float            @default(0) @map("amount_paid")
  paymentRef String?          @map("payment_ref")
  enrolledAt DateTime         @default(now()) @map("enrolled_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  course     VideoCourse      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school     School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  progress   LessonProgress[]

  @@unique([courseId, studentId])
  @@index([courseId])
  @@index([studentId])
  @@index([schoolId])
  @@map("course_enrollments")
}

model LessonProgress {
  id             String           @id @default(uuid())
  enrollmentId   String           @map("enrollment_id")
  lessonId       String           @map("lesson_id")
  studentId      String           @map("student_id")
  completed      Boolean          @default(false)
  lastPosition   Int              @default(0) @map("last_position")
  completedAt    DateTime?        @map("completed_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  enrollment     CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson         VideoLesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([lessonId])
  @@index([studentId])
  @@map("lesson_progress")
}

model CourseRating {
  id        String      @id @default(uuid())
  courseId  String      @map("course_id")
  studentId String      @map("student_id")
  rating    Int
  review    String?
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  course    VideoCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([courseId])
  @@index([studentId])
  @@map("course_ratings")
}
